{{template "base" .}}

{{define "main"}}

<div class="album py-5 bg-light">
    <div class="container">
        <form class="admin-form mb-4" action="/showtimes/create" method="POST">
            <div class="form-row align-items-end">
                <div class="col-md-4 mb-2">
                    <label for="showtime-date">Date</label>
                    <input class="form-control" id="showtime-date" name="date" type="date" required>
                </div>
                <div class="col-md-2 mb-2">
                    <button class="btn btn-primary btn-block" type="submit">Create</button>
                </div>
            </div>
            <label class="d-block mt-3">Movies</label>
            <div class="booking-movie-grid">
                {{range .AvailableMovies}}
                <label class="booking-movie-option">
                    <input type="checkbox" name="movies" value="{{.ID.Hex}}">
                    <img src="{{posterURL .Title}}" alt="{{.Title}} poster" onerror="this.onerror=null;this.src='/static/img/posters/cinema-placeholder.svg';">
                    <span>{{.Title}}</span>
                </label>
                {{end}}
            </div>
        </form>

        <div class="row">
            {{range .ShowTimes}}
            <div class="col-md-3">
                <div class="card mb-3 shadow-sm">
                    <div class="card-body">
                        <p class="card-text">{{.Date}}</p>
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="btn-group">
                                <a class="btn btn-sm btn-outline-secondary" href="/showtimes/view/{{.ID.Hex}}" role="button">View</a>
                                <form action="/showtimes/delete/{{.ID.Hex}}" method="POST">
                                    <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            {{end}}
        </div>

    </div>
</div>

{{end}}
