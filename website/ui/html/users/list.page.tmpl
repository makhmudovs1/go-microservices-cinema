{{template "base" .}}

{{define "main"}}

<div class="album py-5 bg-light">
    <div class="container">
        <form class="admin-form mb-4" action="/users/create" method="POST">
            <div class="form-row align-items-end">
                <div class="col-md-3 mb-2">
                    <label for="user-name">First name</label>
                    <input class="form-control" id="user-name" name="name" type="text" required>
                </div>
                <div class="col-md-3 mb-2">
                    <label for="user-lastname">Last name</label>
                    <input class="form-control" id="user-lastname" name="lastname" type="text" required>
                </div>
                <div class="col-md-4 mb-2">
                    <label for="user-email">Email</label>
                    <input class="form-control" id="user-email" name="email" type="email" required>
                </div>
                <div class="col-md-2 mb-2">
                    <button class="btn btn-primary btn-block" type="submit">Create</button>
                </div>
            </div>
        </form>

        <div class="row">
            {{range .Users}}
            <div class="col-md-3">
                <div class="card mb-3 shadow-sm">
                    <div class="card-body">
                        <p class="card-text">{{.Name}} {{.LastName}}</p>
                        {{if .Email}}
                        <p class="card-text text-muted">{{.Email}}</p>
                        {{else}}
                        <p class="card-text text-muted">No email</p>
                        {{end}}
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="btn-group">
                                <a class="btn btn-sm btn-outline-secondary" href="/users/view/{{.ID.Hex}}" role="button">View</a>
                                <form action="/users/delete/{{.ID.Hex}}" method="POST">
                                    <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            {{end}}
        </div>

    </div>
</div>

{{end}}
