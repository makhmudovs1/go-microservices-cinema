{{template "base" .}}

{{define "main"}}

<div class="album py-5 bg-light">
    <div class="container">

        <div class="row d-flex justify-content-center">
            <div class="col-md-8">
                <div class="card mb-3 shadow-sm">
                    <div class="card-body">
                        <div class="form-group row d-flex justify-content-center">
                            <span class="col-md-6 text-right">Full Username:</span>
                            <span class="col-md-6 text-left">{{.BookingData.UserFullName}}</span>
                        </div>
                        <div class="form-group row d-flex justify-content-center">
                            <span class="col-md-6 text-right">ShowTime Date:</span>
                            <span class="col-md-6 text-left">{{.BookingData.ShowTimeDate}}</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <h2 class="h4 mb-3">Selected movies</h2>
        <div class="row">
            {{range .SelectedMovies}}
            <div class="col-md-3">
                <div class="card movie-card mb-3 shadow-sm">
                    <img class="movie-poster" src="{{posterURL .Title}}" alt="{{.Title}} poster" onerror="this.onerror=null;this.src='/static/img/posters/cinema-placeholder.svg';">
                    <div class="card-body">
                        <p class="card-text">{{.Title}}</p>
                        <p class="card-text text-muted mb-2">{{.Director}}</p>
                        <p class="card-text text-muted mb-0">Rating: {{.Rating}}</p>
                    </div>
                </div>
            </div>
            {{else}}
            <div class="col-md-12">
                <p class="text-muted">No movies selected for this booking.</p>
            </div>
            {{end}}
        </div>

    </div>
</div>

{{end}}
