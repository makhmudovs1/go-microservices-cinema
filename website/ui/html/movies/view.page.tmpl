{{template "base" .}}

{{define "main"}}

<div class="album py-5 bg-light">
    <div class="container">

        <div class="row d-flex justify-content-center">
            <div class="col-md-8">
                <div class="card mb-3 shadow-sm">
                    <div class="row no-gutters">
                        <div class="col-md-4">
                            <img class="movie-poster-detail" src="{{posterURL .Title}}" alt="{{.Title}} poster" onerror="this.onerror=null;this.src='/static/img/posters/cinema-placeholder.svg';">
                        </div>
                        <div class="col-md-8">
                            <div class="card-body">
                                <div class="form-group row">
                                    <span class="col-md-4 text-right">Title:</span>
                                    <span class="col-md-8 text-left">{{.Title}}</span>
                                </div>
                                <div class="form-group row">
                                    <span class="col-md-4 text-right">Director:</span>
                                    <span class="col-md-8 text-left">{{.Director}}</span>
                                </div>
                                <div class="form-group row">
                                    <span class="col-md-4 text-right">Rating:</span>
                                    <span class="col-md-8 text-left">{{.Rating}}</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

{{end}}
